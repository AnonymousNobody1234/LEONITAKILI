# ── Server ─────────────────────────────────────────────
PORT=3000

# ── AI brain ───────────────────────────────────────────
# mock   = canned, instant, $0 (default — great for trying it out)
# ollama = free local model, $0 per task (needs Ollama running)
# openai = paid API, smart, BUT capped by MONTHLY_USD_CAP below
LLM_PROVIDER=mock

# ── HARD money guard ───────────────────────────────────
# Max dollars the app may EVER spend in a calendar month on paid APIs.
# mock and ollama are always $0 and ignore this. Once paid spend would
# cross this number, the app REFUSES the call instead of spending.
MONTHLY_USD_CAP=0

# ── Scheduler ──────────────────────────────────────────
SCHEDULER_ENABLED=true
# Default schedule for tasks that don't set their own (Polsia-style 3am nightly)
DEFAULT_CRON=0 3 * * *

# ── Ollama (free local) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI-compatible (paid, only used if LLM_PROVIDER=openai) ──
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Pricing used to estimate & track spend (USD per 1M tokens).
# Defaults below are gpt-4o-mini list pricing; adjust to your model.
OPENAI_INPUT_USD_PER_MTOK=0.15
OPENAI_OUTPUT_USD_PER_MTOK=0.60
